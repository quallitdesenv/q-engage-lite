{
    "app" : {
        "name": "Q-Engage Lite",
        "version": "1.0.0",
        "description": "A lightweight version of Q-Engage for small to medium-sized businesses.",
        "author": "Quallity Solutions",
        "license": "MIT",
        "model": {
            "name": "ssci_v2",
            "version": "2.0",
            "description": "State-of-the-art model for accurate people counting and demographic analysis.",
            "pretrained": true,
            "source": "./pretrained/ssci_v2.pt"
        },
        "classifier": {
            "name": "gender_classifier",
            "version": "1.0",
            "description": "A simple gender classification model based on a lightweight CNN architecture.",
            "pretrained": true,
            "source": "./pretrained/gender_classifier_v1.pt"
        },
        "store": {
            "timelapse_seconds": 10
        },
        "tracker": {
            "max_age": 70,
            "min_hits": 3,
            "iou_threshold": 0.25,
            "feature_weight": 0.7,
            "min_feature_similarity": 0.65
        }
    },
    "camera" : {
        "id": "1",
        "resolution": "640x480",
        "frame_rate": 0.06,
        "night_vision": true,
        "motion_detection": true,
        "rtsp_url": "./tests/samples/video/security-footage-people-walking-shopping-footage-070595440_main_xxl.mp4",
        "gstream": false
    },
    "event": {
        "driver": "local",
        "path": "./tmp/events"
    },
    "mqtt": {
        "enabled": false,
        "broker": "mqtt.example.com",
        "port": 1883,
        "username": "mqtt_user",
        "password": "mqtt_password",
        "topic": "q-engage-lite/data"
    }
}